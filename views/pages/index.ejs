<!DOCTYPE html>
<html lang="tr">

<%- include('../partials/head') %>
  </head>

  <body>
    <div class="cyber-grid"></div>
    <div class="glow-overlay"></div>
    <%- include('../partials/navbar') %>

      <section class="hero fade-in-section" id="hero">
        <div class="container hero-container">
          <div class="hero-header">
            <h1 class="hero-title">
              <span class="title-top">KARADENİZ</span>
              <span class="title-bottom">GAME JAM 2026</span>
            </h1>

            <div class="hero-meta">
              <div class="meta-chip">
                <span class="chip-icon">📍</span>
                <span class="chip-text">Çarşıbaşı Meslek Yüksekokulu</span>
              </div>
              <div class="meta-chip chip-magenta">
                <span class="chip-icon">📅</span>
                <span class="chip-text">15–16–17 Mayıs</span>
              </div>
            </div>
          </div>

          <p class="hero-description">
            48 saat boyunca hayal gücünü konuştur, takımınla birlikte sıfırdan bir oyun geliştir ve ödüller kazan.
            Deneyim seviyesi fark etmez — herkes davetli.
          </p>



          <div class="hero-countdown">
            <div class="countdown-grid" id="countdown" data-target="2026-05-15T10:00:00+03:00">
              <div class="countdown-card">
                <span class="card-number" id="countdown-days">00</span>
                <span class="card-label">GÜN</span>
              </div>
              <div class="countdown-card">
                <span class="card-number" id="countdown-hours">00</span>
                <span class="card-label">SAAT</span>
              </div>
              <div class="countdown-card">
                <span class="card-number" id="countdown-minutes">00</span>
                <span class="card-label">DAKİKA</span>
              </div>
              <div class="countdown-card">
                <span class="card-number" id="countdown-seconds">00</span>
                <span class="card-label">SANİYE</span>
              </div>
            </div>
          </div>

          <!-- CTA Buttons + OAuth -->
          <% if (registrationOpen) { %>
            <div class="hero-actions">
              <a href="/kayit-formu" class="btn-premium primary">
                <span class="btn-icon">🎟️</span>
                <span class="btn-text">Kayıt Ol</span>
              </a>
              <a href="#" class="btn-premium secondary">
                <span class="btn-icon">📄</span>
                <span class="btn-text">Katılımcı Rehberi</span>
              </a>
            </div>
            <style>
              .btn-scan::after {
                content: "";
                position: absolute;
                top: 0;
                left: -100%;
                width: 50%;
                height: 100%;
                background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.2), transparent);
                transform: skewX(-25deg);
                animation: btnScan 3s infinite;
              }
            </style>

            <!-- OAuth Social Logins REMOVED -->

            <% } else { %>

              <!-- KAYITLAR KAPANDI — shown on hero when closed -->
              <div
                style="margin-top: var(--space-xl); display: flex; flex-direction: column; align-items: center; gap: var(--space-md);">
                <div style="
          font-family: var(--font-display);
          font-size: clamp(1.4rem, 4.5vw, 2.2rem);
          font-weight: 900;
          letter-spacing: 0.14em;
          color: #ff2244;
          text-shadow: 0 0 16px rgba(255,34,68,0.85), 0 0 40px rgba(255,34,68,0.45);
          animation: heroClosedPulse 2s ease-in-out infinite;
          text-align: center;
        ">⛔ KAYITLAR KAPANDI</div>
                <a href="#program" class="btn btn-secondary btn-lg">📋 Programı Gör</a>
              </div>

              <style>
                @keyframes heroClosedPulse {

                  0%,
                  100% {
                    text-shadow: 0 0 16px rgba(255, 34, 68, 0.85), 0 0 40px rgba(255, 34, 68, 0.45);
                  }

                  50% {
                    text-shadow: 0 0 28px rgba(255, 34, 68, 1), 0 0 60px rgba(255, 34, 68, 0.7);
                  }
                }
              </style>

              <% } %>

                <!-- Presented By -->
                <div class="hero-presented">
                  <p>Düzenleyen</p>
                  <img src="/images/club-logo.png" alt="KTÜ Oyun Geliştirme Kulübü"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                  <p
                    style="display:none; font-size: 0.9rem; color: var(--neon-cyan); font-family: var(--font-display);">
                    KTÜ Oyun Geliştirme Kulübü
                    Next-Gen Kulübü
                    TRÜ Oyun Geliştirme Kulübü
                  </p>
                </div>
        </div>
      </section>

      <!-- ═══ SPONSOR MARQUEE (Above-the-fold) ═════════════════════════ -->
