              <p class="prize-desc">Yüksek performans gösteren ve harika bir deneyim sunan projeye.</p>
            </div>

            <!-- 1st Place (Center, Largest) -->
            <div class="prize-card prize-gold" style="transform: scale(1.05); z-index: 10;">
              <div class="prize-icon">🏆</div>
              <div class="prize-rank">1.lik Ödülü</div>
              <div class="prize-reward">100.000 ₺</div>
              <p class="prize-desc">Temayı en yenilikçi şekilde yorumlayan ve kusursuz çalışan projeye.</p>
            </div>

            <!-- 3rd Place -->
            <div class="prize-card prize-bronze">
              <div class="prize-icon">🥉</div>
              <div class="prize-rank">3.lük Ödülü</div>
              <div class="prize-reward">25.000 ₺</div>
              <p class="prize-desc">Yaratıcı yaklaşımıyla dikkat çeken yarışmacı projeye.</p>
            </div>
          </div>

          <!-- Special Categories -->
          <div class="special-prizes fade-in">
            <h3 class="special-prizes-title">Özel Ödüller</h3>
            <div class="special-prizes-grid">
              <div class="special-prize-card">
