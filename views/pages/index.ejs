            box-shadow: 0 0 18px rgba(128, 0, 0, 0.12);
          }

          .sponsor-card-extra:hover img {
            filter: brightness(0.95) saturate(0.9) grayscale(0);
          }

          a .sponsor-card-main,
          a .sponsor-card-extra {
            cursor: pointer;
          }
        </style>

      </section>

      <!-- ═══ CTA BANNER ═══════════════════════════════════════════════ -->
      <% if (registrationOpen) { %>
        <section
          style="background: linear-gradient(135deg, rgba(var(--neon-cyan-rgb), 0.08), rgba(var(--neon-magenta-rgb), 0.08)); border-top: 1px solid var(--border-glow); border-bottom: 1px solid var(--border-glow);">
          <div class="container text-center fade-in">
            <h2 style="margin-bottom: var(--space-md);">Yerini Ayırt! 🎮</h2>
            <p style="margin: 0 auto var(--space-xl); max-width: 500px; text-align: center;">
              Kontenjan sınırlıdır. Hemen kaydını oluştur ve 48 saatlik maceraya katıl!
            </p>
            <a href="/kayit-formu" class="btn btn-primary btn-lg">Kayıt Ol →</a>
          </div>
        </section>
        <% } %>

          <!-- ═══ FOOTER ═══════════════════════════════════════════════════ -->
          <%- include('../partials/footer') %>

            <script src="/js/main.js"></script>
  </body>

</html>