            </div>
            <div class="marquee-item">
              <span class="sponsor-text">◆ Sponsor Beta</span>
            </div>
            <div class="marquee-item">
              <span class="sponsor-text">◆ Sponsor Gamma</span>
            </div>
            <div class="marquee-item">
