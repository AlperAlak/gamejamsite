            </div>
            <div class="marquee-item">
              <span class="sponsor-text">◆ Sponsor Epsilon</span>
            </div>
            <div class="marquee-item">
              <span class="sponsor-text">◆ Sponsor Zeta</span>
            </div>
            <div class="marquee-item">
              <span class="sponsor-text">◆ Sponsor Eta</span>
            </div>
            <div class="marquee-item">
