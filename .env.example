# ─── Server ──────────────────────────────────────────────
PORT=3000

# ─── Session Secret ──────────────────────────────────────
# A long random string used to sign the session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# ─── Admin Credentials ──────────────────────────────────
# Password required to access the /admin dashboard.
ADMIN_PASSWORD=change-me-to-a-strong-password

# ─── WhatsApp Community Link ─────────────────────────────
# Participants are redirected here after successful registration.
WHATSAPP_LINK=https://chat.whatsapp.com/your-community-invite-link

# ─── Event Configuration ─────────────────────────────────
# ISO 8601 date string for the event start (used by the countdown timer).
EVENT_START_DATE=2026-08-15T10:00:00+03:00
EVENT_END_DATE=2026-08-17T18:00:00+03:00
